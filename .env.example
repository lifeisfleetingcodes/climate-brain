# ClimateBrain Configuration
# Copy this file to .env and fill in your values

# === SwitchBot API ===
# Get these from the SwitchBot app: Profile > Preferences > Developer Options
SWITCHBOT_TOKEN=your_switchbot_token_here
SWITCHBOT_SECRET=your_switchbot_secret_here

# === OpenWeatherMap ===
# Sign up free at https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here
# Your location coordinates (default: Jakarta)
OPENWEATHER_LAT=-6.2088
OPENWEATHER_LON=106.8456

# === Server ===
HOST=0.0.0.0
PORT=8000
DEBUG=false

# === Scheduler ===
SCHEDULER_ENABLED=true
CONTROL_INTERVAL_MINUTES=5

# === Learning Parameters ===
# Minimum feedback data points before the system starts auto-adjusting
MIN_FEEDBACK_POINTS=20
# How often to retrain the room thermal model (hours)
THERMAL_RETRAIN_HOURS=6
# How often to retrain per-person comfort models (hours)
COMFORT_RETRAIN_HOURS=12

# === Optimization ===
# Strategy: "minimax" (fairest), "utilitarian" (average happy), "weighted"
OPTIMIZATION_STRATEGY=minimax
# Temperature search range around current setpoint (degrees C)
TEMP_SEARCH_RANGE=4
